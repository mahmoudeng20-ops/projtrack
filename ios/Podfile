# السطر الرسمي والوحيد المعتمد من Flutter لاستدعاء وإعداد دالة الـ Plugins
ffpath = File.expand_path(File.join('packages', 'flutter_tools', 'templates', 'cocoapods', 'Podfile-flutter-plugins'), File.dirname(File.realpath(__FILE__)))
# استخدام load بدلاً من import لقراءة الملف برمجياً في لغة Ruby
load ffpath if File.exist?(ffpath)

# تحديد الإصدار الأدنى لـ iOS في المشروع
platform :ios, '15.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # تثبيت كافة الـ Plugins الخاصة بـ Flutter تلقائياً (مثل الفايربيز)
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    # استدعاء الإعدادات الافتراضية الرسمية لمحرك Flutter
    flutter_additional_ios_build_settings(target)
    
    if target.respond_to?(:build_configurations)
      target.build_configurations.each do |config|
        # 1. توحيد إصدار البناء لكافة المكتبات والـ Plugins على iOS 15
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
        config.build_settings['ENABLE_BITCODE'] = 'NO'
        
        # 2. تعديل مسارات الـ Pods لمنع تضارب الـ Sandbox على السيرفر السحابي
        config.build_settings['PODS_PODFILE_DIR_PATH'] = '$(SRCROOT)'
        config.build_settings['PODS_ROOT'] = '$(SRCROOT)/Pods'
      end
    end
  end
  
  # 3. تخطي الفحص الصارم للـ Sandbox لمنع انهيار البناء على Codemagic
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_project.targets.each do |user_target|
      user_target.build_phases.each do |phase|
        if phase.respond_to?(:name) && phase.name == 'Check Pods Manifest.lock'
          phase.shell_script = "echo 'Skipping Sandbox Sync Check on Codemagic Cloud'"
        end
      end
    end
  end
end