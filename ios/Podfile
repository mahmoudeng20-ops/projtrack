# السطور التالية أساسية لربط ملفات فلاتر بالـ Pods وإتاحة الدوال الذكية
podb_helpers_path = File.expand_path(File.join('..', '..', '.symlinks', 'plugins', 'flutter_plugin_android_lifecycle', 'ios', 'Classes'), __FILE__)
# استدعاء ملف فلاتر التعريفي الرئيسي لبيئة iOS
import File.expand_path(File.join('..', '..', '..', 'packages', 'flutter_tools', 'templates', 'cocoapods', 'Podfile-flutter-plugins'), __FILE__) rescue nil

# في حال فشل الاستدعاء النسبي المباشر (وهو الأضمن للمنصات السحابية):
podb_fallback = File.expand_path('Generated.xcconfig', __dir__)
if File.exist?(podb_fallback)
  txt = File.read(podb_fallback)
  flutter_root = txt[/FLUTTER_ROOT=(.+)/, 1]
  if flutter_root
    require File.expand_path('packages/flutter_tools/bin/podhelper', flutter_root)
  end
end

# الإصدار الأدنى لمنصة iOS للمشروع
platform :ios, '15.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # الدالة أصبحت الآن معرفة بفضل السطور السابقة
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    if target.respond_to?(:build_configurations)
      target.build_configurations.each do |config|
        # 1. توحيد الإصدار لكافة المكتبات والـ Plugins
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
        config.build_settings['ENABLE_BITCODE'] = 'NO'
        
        # 2. حل تضارب مسارات الـ Sandbox في السيرفر السحابي
        config.build_settings['PODS_PODFILE_DIR_PATH'] = '$(SRCROOT)'
        config.build_settings['PODS_ROOT'] = '$(SRCROOT)/Pods'
      end
    end
  end
  
  # 3. تخطي فحص تزامن الملفات لمنع انهيار البيئة الافتراضية
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_project.targets.each do |user_target|
      user_target.build_phases.each do |phase|
        if phase.respond_to?(:name) && phase.name == 'Check Pods Manifest.lock'
          phase.shell_script = "echo 'Skipping Sandbox Sync Check on Codemagic Cloud'"
        end
      end
    end
  end
end