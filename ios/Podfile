platform :ios, '13.0'

# كود حقن وتنظيف السيرفر وإعادة توليد الإعدادات للماك سحابياً
# ------------------------------------------------------------------------
if ENV['CI']
  puts "🚀 CI Environment detected! Regenerating native Mac configurations..."
  system("rm -f Podfile.lock")
  system("rm -rf Pods")
  system("rm -rf .symlinks")
  system("rm -rf Flutter/ephemeral")
  
  # إجبار السيرفر على تحديث روابط الفلاتر المتوافقة مع الماك سحابياً
  system("flutter pub get")
end
# ------------------------------------------------------------------------

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    # إذا لم يجد الملف سيبحث السيرفر عن مسار الفلاتر الافتراضي في الماك السحابي
    return ENV['FLUTTER_ROOT'] if ENV['FLUTTER_ROOT']
    raise "Generated.xcconfig not found. Please run `flutter pub get`."
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT=(.*)/)
    return matches[1].strip if matches
  end
  ENV['FLUTTER_ROOT'] ? ENV['FLUTTER_ROOT'] : (raise "FLUTTER_ROOT not found.")
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper.rb'), flutter_root)

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_ios_podfile_setup
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end
end