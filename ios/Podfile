# Force fresh cloud build compilation after cache clear
# الإصدار الأدنى لمنصة iOS للمشروع
platform :ios, '15.0'

# ميزة تسريع البناء عبر سحب حزم الفلاتر مسبقة التجميع
target 'Runner' do
  use_frameworks!
  use_modular_headers!
  
  # تم تعديل الكلمة هنا لتصبح بأحرف كبيرة __FILE__ لتتعرف عليها لغة Ruby بشكل سليم
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    if target.respond_to?(:build_configurations)
      target.build_configurations.each do |config|
        # 1. إجبار كافة الحزم على العمل بإصدار 15.0 لتوحيد بيئة العمل
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
        config.build_settings['ENABLE_BITCODE'] = 'NO'
        
        # 2. توجيه مسارات الـ Pods لمنع Xcode من إيقاف البناء بسبب عدم تطابق الـ Sandbox مع الـ Lockfile
        config.build_settings['PODS_PODFILE_DIR_PATH'] = '$(SRCROOT)'
        config.build_settings['PODS_ROOT'] = '$(SRCROOT)/Pods'
      end
    end
  end
  
  # 3. إجبار السيرفر على تحديث وتخطي الـ SandboxScript تلقائياً أثناء البناء السحابي
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_project.targets.each do |user_target|
      user_target.build_phases.each do |phase|
        if phase.respond_to?(:name) && phase.name == 'Check Pods Manifest.lock'
          # تعطيل فحص الخطأ الصارم الذي يوقف السيرفر
          phase.shell_script = "echo 'Skipping Sandbox Sync Check on Codemagic Cloud'"
        end
      end
    end
  end
end