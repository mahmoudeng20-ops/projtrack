platform :ios, '13.0'

# دالة ذكية لجلب مسار فلاتر سواء كنت على الويندوز أو سيرفر Codemagic
def flutter_root
  # أولاً: محاولة البحث عن المسار في بيئة السيرفر (Codemagic)
  if ENV['FLUTTER_ROOT']
    return ENV['FLUTTER_ROOT']
  end

  # ثانياً: إذا لم يوجد (مثل جهازك المحلي)، نعود للطريقة التقليدية
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "Generated.xcconfig not found. Please run `flutter pub get`."
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in Generated.xcconfig."
end

# تحميل أدوات فلاتر بناءً على المسار الذي وجدناه
require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper.rb'), flutter_root)

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_ios_podfile_setup
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # توحيد إصدار Target لجميع المكتبات لضمان التوافق
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      # حل مشكلة الساندبوكس برمجياً
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
    end
  end
end